{
  "name": "pofuserver-coder-studio",
  "productName": "Pofuserver Coder Studio",
  "version": "1.0.0",
  "description": "Pofuserver Coder Studio — agente de código em desktop (Electron) que se conecta a qualquer API REST compatível com OpenAI (llama.cpp, Ollama, vLLM, etc.). O agente lê, escreve e apaga arquivos do workspace, executa comandos no terminal com gerenciamento inteligente de processos em segundo plano (sobe servidores/APIs sem travar o chat), aceita anexos de arquivos e renderiza respostas em Markdown com realce de código.",
  "main": "main.js",
  "scripts": {
    "start": "electron --no-sandbox . --ozone-platform=x11",
    "dist:linux": "electron-builder --linux deb",
    "dist:win": "electron-builder --win nsis",
    "dist": "electron-builder --linux deb --win nsis"
  },
  "keywords": [
    "code-agent",
    "ai-agent",
    "electron",
    "openai-compatible",
    "llm",
    "llama.cpp",
    "developer-tools",
    "coding-assistant"
  ],
  "author": "Dspofu",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "openai": "^6.46.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.dspofu.pofusercoderstudio",
    "productName": "Pofuserver Coder Studio",
    "copyright": "Copyright © 2026 Dspofu",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "vendor/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Development",
      "maintainer": "Dspofu",
      "icon": "assets/icon.png"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "build/license.txt"
    }
  }
}
